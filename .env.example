# Copy to .env and fill in real values. .env is gitignored.
#
# These are for LOCAL `terraform plan` only. Production plan/apply runs on
# HCP Terraform (VCS-Driven, Remote execution) with its OWN copy of these
# values configured inside the HCP workspace (Variables tab).
#
# `make secrets-sync` is still available for OTHER workflows that may need
# GitHub Actions secrets — it just has nothing to push for this DNS setup.

# --- Vercel (local `terraform plan` only) ---
# https://vercel.com/account/tokens — scope to the team that owns hardway.app.
VERCEL_API_TOKEN=
# Optional. Team settings -> General -> Team ID. Leave empty for personal account.
VERCEL_TEAM_ID=

# --- App Store Connect API Key (for `make release`) ---
# Detailed one-time setup: see docs/release.md
#
# Create at: https://appstoreconnect.apple.com/access/integrations/api
# Role: App Manager (Developer is NOT enough for metadata/screenshot upload).
# Download the .p8 file once — it can't be re-downloaded.
#
# With this key set, `make release` will:
#   1. Auto-create the App record on ASC via fastlane produce (idempotent)
#   2. Rebuild screenshots in the simulator
#   3. Upload metadata (if fastlane/metadata/ exists) + screenshots
# No App needs to be pre-created on App Store Connect.
#
# Makefile auto-loads this file, so `make release` alone is enough —
# no manual `source .env` required.
APP_STORE_CONNECT_KEY_IDENTIFIER=
APP_STORE_CONNECT_ISSUER_ID=
# Absolute path to the downloaded .p8 file. Keep the file OUTSIDE this repo
# (e.g. ~/.appstoreconnect/AuthKey_XXXXXXXXXX.p8).
APP_STORE_CONNECT_PRIVATE_KEY_PATH=
