# Copy to .env and fill in real values. .env is gitignored.
#
# These are for LOCAL `terraform plan` only. Production plan/apply runs on
# HCP Terraform (VCS-Driven, Remote execution) with its OWN copy of these
# values configured inside the HCP workspace (Variables tab).
#
# `make secrets-sync` is still available for OTHER workflows that may need
# GitHub Actions secrets — it just has nothing to push for this DNS setup.

# --- Vercel (local `terraform plan` only) ---
# https://vercel.com/account/tokens — scope to the team that owns hardway.app.
VERCEL_API_TOKEN=
# Optional. Team settings -> General -> Team ID. Leave empty for personal account.
VERCEL_TEAM_ID=
